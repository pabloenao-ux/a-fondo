[
  { "id": "sobrevivir-inteligencia-artificial", "numero": 1, "archivo": "ep_01_Quiénes_sobrevivirán_realmente_a_la_inteligencia_artificial.m4a", "titulo": "Quiénes sobrevivirán realmente a la inteligencia artificial", "tags": ["Inteligencia Artificial", "Sociedad"], "bg": "noche", "audio": "", "porque": "", "resumen": "Una investigación sobre qué tan preparados están los trabajadores de EE. UU. para un despido causado por la inteligencia artificial. Los autores construyen un «índice de capacidad adaptativa» —ahorros, edad, ubicación y transferibilidad de habilidades— y concluyen que la mayoría de los más expuestos sí tiene con qué reinventarse. El problema son los millones en tareas administrativas y de oficina con baja capacidad de respuesta: para ellos, perder el empleo sale caro. La meta del estudio es que las políticas públicas enfoquen el apoyo en esa población.", "ideas": ["No basta con estar expuesto a la IA: lo que decide tu futuro es poder adaptarte.", "El índice mide cuatro factores: ahorros, edad, ubicación y transferencia de habilidades.", "La mayoría de los más expuestos sí tiene con qué reinventarse; los vulnerables son millones en oficina y tareas administrativas.", "El objetivo no es predecir el desempleo, sino orientar hacia dónde dirigir el apoyo público."] },
